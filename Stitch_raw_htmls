<script>
        function toggleSegment(type) {
            const meBtn = document.getElementById('segment-me');
            const adminBtn = document.getElementById('segment-admin');
            
            if (type === 'me') {
                meBtn.classList.add('active-tab');
                meBtn.classList.remove('text-on-surface-variant');
                adminBtn.classList.remove('active-tab');
                adminBtn.classList.add('text-on-surface-variant');
            } else {
                adminBtn.classList.add('active-tab');
                adminBtn.classList.remove('text-on-surface-variant');
                meBtn.classList.remove('active-tab');
                meBtn.classList.add('text-on-surface-variant');
            }
        }

        function toggleSwitch(id) {
            const switchEl = document.getElementById('switch-' + id);
            const knobEl = document.getElementById('knob-' + id);
            
            if (switchEl.classList.contains('bg-primary')) {
                switchEl.classList.remove('bg-primary');
                switchEl.classList.add('bg-surface-container-high');
                knobEl.style.transform = 'translateX(0)';
            } else {
                switchEl.classList.add('bg-primary');
                switchEl.classList.remove('bg-surface-container-high');
                knobEl.style.transform = 'translateX(24px)';
            }
        }

        // Minimal micro-interaction for primary button
        document.querySelector('button.bg-primary').addEventListener('click', function() {
            this.innerHTML = `<span class="animate-spin material-symbols-outlined">progress_activity</span>`;
            setTimeout(() => {
                this.innerHTML = `Complete <span class="material-symbols-outlined text-sm">check</span>`;
                this.classList.replace('bg-primary', 'bg-primary-container');
            }, 1000);
        });
    </script>
