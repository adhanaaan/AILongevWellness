<script>
        // Micro-interaction: Mimicking the two-stage sign off flow for demo
        document.addEventListener('DOMContentLoaded', () => {
            const gpBtn = document.querySelector('button:contains("Sign off (GP)")') || document.querySelectorAll('button')[2];
            const tcmSection = document.querySelectorAll('.space-y-4')[2];
            const releaseBtn = document.getElementById('release-btn');
            
            // Note: In a real app this would be state-driven.
            // Using a simple click simulation for UI fidelity.
            gpBtn.addEventListener('click', () => {
                gpBtn.classList.remove('bg-primary');
                gpBtn.classList.add('bg-primary-container', 'text-on-primary-container');
                gpBtn.innerHTML = '<span class="material-symbols-outlined text-sm mr-2">check</span>Signed';
                
                tcmSection.classList.remove('opacity-50', 'cursor-not-allowed');
                const tcmArea = tcmSection.querySelector('textarea');
                tcmArea.removeAttribute('disabled');
                tcmArea.classList.remove('bg-surface-container');
                tcmArea.classList.add('bg-white');
                tcmArea.placeholder = "Enter TCM insights...";
                tcmArea.value = "";
                
                const tcmBtn = tcmSection.querySelector('button');
                tcmBtn.removeAttribute('disabled');
                tcmBtn.classList.remove('bg-surface-variant', 'cursor-not-allowed');
                tcmBtn.classList.add('bg-primary', 'text-white', 'hover:opacity-90');
                
                tcmBtn.addEventListener('click', () => {
                    tcmBtn.classList.remove('bg-primary');
                    tcmBtn.classList.add('bg-primary-container', 'text-on-primary-container');
                    tcmBtn.innerHTML = '<span class="material-symbols-outlined text-sm mr-2">check</span>Signed';
                    
                    releaseBtn.removeAttribute('disabled');
                    releaseBtn.classList.remove('bg-surface-variant', 'text-on-surface-variant/40', 'cursor-not-allowed');
                    releaseBtn.classList.add('bg-primary', 'text-white', 'hover:bg-primary/90', 'shadow-lg', 'scale-105');
                });
            });
        });
    </script>
