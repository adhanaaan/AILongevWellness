# Copy the values from your Supabase project (Project Settings -> API) and
# your Anthropic console (console.anthropic.com -> API Keys). Set these on
# Vercel (Project Settings -> Environment Variables) for the deployed app.
#
# Leave everything unset for local mock-data mode (no real backend, no auth).

# --- Client-safe: bundled into the app, protected by RLS, not secret ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-only: never prefix these with EXPO_PUBLIC_, never ship to the client ---
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=

# --- Optional: only needed for native (iOS/Android) builds ---
# Web deploys call /api/* on the same origin and can leave this unset.
# Native builds have no "origin", so point this at the deployed Vercel URL.
EXPO_PUBLIC_API_BASE_URL=
